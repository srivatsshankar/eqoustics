{
  "name": "eqoustics",
  "private": true,
  "version": "0.0.0-beta.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "prepare:python": "node scripts/prepare-python-env.mjs",
    "prepare:python:dev": "node scripts/prepare-python-env.mjs --skip-portable",
    "build": "npm run build:win",
    "build:app": "tsc && vite build",
    "build:win": "npm run build:app && npm run prepare:python && electron-builder --win",
    "build:all": "npm run build:win",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@ricky0123/vad-web": "^0.0.30",
    "electron-store": "^10.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.2",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js"
}
